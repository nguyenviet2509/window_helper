{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (dynamic, fast dev)",
      "description": "Existing dynamic build — opencv DLLs next to exe.",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "portable",
      "displayName": "Portable (static, zero-dep single exe)",
      "description": "Static link MSVC CRT + OpenCV + deps. Single exe, no DLLs, no VC++ Redist needed. First build slow (~15-30min compiling OpenCV static).",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build-portable",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default-release",
      "configurePreset": "default",
      "configuration": "Release",
      "targets": ["WindowHelper"]
    },
    {
      "name": "portable-release",
      "configurePreset": "portable",
      "configuration": "Release",
      "targets": ["WindowHelper"]
    }
  ]
}
